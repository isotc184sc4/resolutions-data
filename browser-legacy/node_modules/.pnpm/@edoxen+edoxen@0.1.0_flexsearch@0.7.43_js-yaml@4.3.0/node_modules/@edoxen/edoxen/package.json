{
  "name": "@edoxen/edoxen",
  "version": "0.1.0",
  "description": "Framework-agnostic TypeScript data layer for the Edoxen meeting/decision information model. JSON-Schema-driven types, YAML loaders, transforms, search, URN, i18n, and validate helpers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*": "./src/schema/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "cli",
    "src/schema"
  ],
  "bin": {
    "edoxen-build": "./cli/build-data.mjs"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:schema": "node scripts/sync-schema.mjs",
    "gen:types": "node scripts/gen-types.mjs"
  },
  "peerDependencies": {
    "ajv": "^8.17.0",
    "flexsearch": "^0.7.31",
    "js-yaml": "^4.1.0"
  },
  "peerDependenciesMeta": {
    "ajv": {
      "optional": true
    },
    "flexsearch": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.17.0",
    "flexsearch": "^0.7.31",
    "js-yaml": "^4.1.0",
    "json-schema-to-typescript": "^15.0.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "BSD-2-Clause",
  "author": "Ribose Inc. <open.source@ribose.com>",
  "homepage": "https://github.com/edoxen/edoxen-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edoxen/edoxen-js.git",
    "directory": "packages/edoxen"
  },
  "bugs": {
    "url": "https://github.com/edoxen/edoxen-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@asciidoctor/core": "^4.0.2",
    "esbuild": "^0.28.1"
  }
}
