{
  "name": "@edoxen/vue",
  "version": "0.1.0",
  "description": "Vue 3 adapter for the Edoxen data layer. Composables + components for existing Vue/Vite consumers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./composables": {
      "types": "./dist/composables/index.d.ts",
      "import": "./dist/composables/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@edoxen/edoxen": "^0.1.0",
    "vue": "^3.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "@edoxen/edoxen": "workspace:*",
    "vue": "^3.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0"
  },
  "license": "BSD-2-Clause",
  "author": "Ribose Inc. <open.source@ribose.com>",
  "homepage": "https://github.com/edoxen/edoxen-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edoxen/edoxen-js.git",
    "directory": "packages/edoxen-vue"
  },
  "bugs": {
    "url": "https://github.com/edoxen/edoxen-js/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
